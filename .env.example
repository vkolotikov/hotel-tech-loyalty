APP_NAME="Hotel Loyalty"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://loyalty.hotel-tech.ai

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hotel_loyalty
DB_USERNAME=
DB_PASSWORD=

CACHE_DRIVER=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="loyalty@hotel-tech.ai"
MAIL_FROM_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# SaaS Core Auth
SAAS_PLATFORM_URL=https://saas.hotel-tech.ai
SAAS_JWT_SECRET=

CORS_ALLOWED_ORIGINS=https://loyalty.hotel-tech.ai

QR_TOKEN_SECRET=
QR_TOKEN_EXPIRY_MINUTES=1440

FCM_SERVER_KEY=
EXPO_ACCESS_TOKEN=

# ─── Per-tenant integrations (configured in admin UI, NOT here) ──────
# Stripe (booking payments), Smoobu (PMS sync + webhook), Apple/Google
# Wallet, and other customer-facing integrations are configured per-org
# in the loyalty admin SPA at Settings → Integrations. Secrets are
# encrypted at rest in hotel_settings via a Crypt accessor. Do NOT add
# STRIPE_SECRET_KEY / SMOOBU_API_KEY / SMOOBU_WEBHOOK_SECRET here — the
# code no longer falls back to env for those keys (this is a multi-tenant
# portal and each customer uses their own Stripe / Smoobu account).
